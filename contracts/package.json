    "deploy:mainnet": "./node_modules/.bin/hardhat run scripts/deploy.js --network hedera_mainnet"
  },
  "dependencies": {
    "@hashgraph/sdk": "^2.50.0",
    "@openzeppelin/contracts": "^5.0.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "hardhat": "~2.28.6"
  }
}
