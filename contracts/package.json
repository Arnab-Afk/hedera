{
  "name": "wisp-contracts",
  "version": "1.0.0",
  "description": "Wisp smart contracts — Hedera / EVM compatible",
  "scripts": {
    "compile":  "hardhat compile",
    "test":     "hardhat test",
    "deploy":         "./node_modules/.bin/hardhat run scripts/deploy.js --network hedera_testnet",
