# Contracts .env — copy to .env and fill in real values

# ── EVM Deployer ─────────────────────────────────────────────────────────────
# ECDSA private key for the deployer wallet (hex, without 0x prefix)
# Get this from Hedera portal by exporting your account's ECDSA key
DEPLOYER_PRIVATE_KEY=your_ecdsa_hex_key_here

# ── Network ───────────────────────────────────────────────────────────────────
# hedera_testnet | hedera_mainnet | localhost
# Passed via: npx hardhat run scripts/deploy.js --network hedera_testnet
HEDERA_NETWORK=hedera_testnet

# ── Deployed Contract Addresses (fill in after running deploy.js) ─────────────
WISP_TOKEN_ADDRESS=
WISP_SPIRIT_ADDRESS=
WISP_CORE_ADDRESS=

# ── Copy these to backend/.env after deployment ───────────────────────────────
# WISP_TOKEN_ID=0.0.XXXXXXX      (HTS token id matching WISP_TOKEN_ADDRESS)
# SPIRIT_NFT_ID=0.0.XXXXXXX      (HTS NFT id matching WISP_SPIRIT_ADDRESS)
# HCS_TOPIC_ID=0.0.XXXXXXX       (Create via Hedera portal or SDK)
