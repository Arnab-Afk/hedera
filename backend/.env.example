# Backend .env — copy to .env and fill in real values

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173    # Set to your frontend URL in production

# ── PostgreSQL ───────────────────────────────────────────────────────────────
PGHOST=your_neon_host
PGDATABASE=neondb
PGUSER=neondb_owner
PGPASSWORD=your_password
PGSSLMODE=require
PGCHANNELBINDING=require

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# ── Hedera ───────────────────────────────────────────────────────────────────
HEDERA_NETWORK=testnet              # testnet | mainnet
HEDERA_ACCOUNT_ID=0.0.XXXXXXX      # Your Hedera operator account id
HEDERA_PRIVATE_KEY=302e...          # DER-encoded ED25519 private key (from Hedera portal)

# ── HTS / NFT Token IDs (from deploy output) ─────────────────────────────────
WISP_TOKEN_ID=0.0.XXXXXXX          # $WISP HTS fungible token id
SPIRIT_NFT_ID=0.0.XXXXXXX          # WispSpirit HTS NFT token id

# ── HCS Topic ─────────────────────────────────────────────────────────────────
HCS_TOPIC_ID=0.0.XXXXXXX           # HCS topic for action proofs
