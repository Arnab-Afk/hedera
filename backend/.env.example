# Server
PORT=3001
NODE_ENV=development

# PostgreSQL (Neon)
PGHOST=your_neon_host
PGDATABASE=neondb
PGUSER=neondb_owner
PGPASSWORD=your_password
PGSSLMODE=require
PGCHANNELBINDING=require

# Hedera
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=0.0.XXXXXXX
HEDERA_OPERATOR_KEY=your_private_key_here
HCS_TOPIC_ID=0.0.XXXXXXX
WISP_TOKEN_ID=0.0.XXXXXXX
WISP_NFT_TOKEN_ID=0.0.XXXXXXX

# JWT
JWT_SECRET=change_me_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d

# Hackathon Demo Bypass
INTERNAL_AGENT_KEY=internal_agent_key

# OpenRouter (AI ticket verification)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
SITE_URL=http://localhost:3001
SITE_NAME=Wisp Backend
