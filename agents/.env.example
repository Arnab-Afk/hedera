# Agents .env — copy to .env and fill in real values

# ── Hedera ───────────────────────────────────────────────────────────────────
HEDERA_NETWORK=testnet              # testnet | mainnet
HEDERA_OPERATOR_ID=0.0.XXXXXXX     # Agent Hedera account (submits HCS messages)
HEDERA_OPERATOR_KEY=302e...         # ED25519 private key for the operator account
HCS_TOPIC_ID=0.0.XXXXXXX           # HCS topic to publish proofs to

# ── Wisp Backend ─────────────────────────────────────────────────────────────
WISP_API_URL=http://localhost:3001/api
WISP_API_KEY=internal_agent_jwt_here   # JWT obtained by agent at startup

# ── Daemon Loop ───────────────────────────────────────────────────────────────
POLL_INTERVAL_MS=300000            # How often agent polls MCP servers (default 5 min)

# ── Local LLM (Ollama) ───────────────────────────────────────────────────────
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=mistral                  # Any Ollama-supported model

# ── MCP Data Sources ─────────────────────────────────────────────────────────
TRANSIT_API_BASE_URL=https://api.example-transit.com
TRANSIT_API_KEY=your_transit_api_key

ENERGY_API_BASE_URL=https://api.example-energy.com
ENERGY_API_KEY=your_energy_api_key

RECEIPT_API_BASE_URL=https://api.example-receipts.com
RECEIPT_API_KEY=your_receipt_api_key
