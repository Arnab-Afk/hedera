# Hedera
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=0.0.XXXXXXX
HEDERA_OPERATOR_KEY=your_private_key_here
HCS_TOPIC_ID=0.0.XXXXXXX

# Wisp Backend API
WISP_API_URL=http://localhost:3001/api
WISP_API_KEY=internal_agent_key

# LLM Configuration (Ollama, OpenAI, or OpenRouter)
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=mistral
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
SITE_URL=http://localhost:3000
SITE_NAME=Wisp Agent

# MCP Data Sources
TRANSIT_API_BASE_URL=https://api.example-transit.com
TRANSIT_API_KEY=your_transit_api_key

ENERGY_API_BASE_URL=https://api.example-energy.com
ENERGY_API_KEY=your_energy_api_key

RECEIPT_API_BASE_URL=https://api.example-receipts.com
RECEIPT_API_KEY=your_receipt_api_key
